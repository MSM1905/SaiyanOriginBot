import re
from telegram.ext import ContextTypes
from telegram import Update


# ======================
# 广告关键词
# ======================

BAD_WORDS = [
    "赌博",
    "博彩",
    "刷单",
    "诈骗",
    "加微信",
    "微信赚钱",
    "裸聊",
    "兼职赚钱",
    "贷款"
]


# ======================
# 判断广告
# ======================

def is_ad(text):

    if not text:
        return False


    text = text.lower()


    # 关键词检测

    for word in BAD_WORDS:

        if word in text:
            return True



    # 链接检测

    url_pattern = r"(https?://|www\.|t\.me/)"

    if re.search(url_pattern, text):

        return True


    return False



# ======================
# 自动删除
# ======================

async def anti_spam(
    update: Update,
    context: ContextTypes.DEFAULT_TYPE
):

    if not update.message:
        return


    if is_ad(update.message.text):

        try:

            await update.message.delete()


            await update.message.chat.send_message(
                "🚫 检测到广告，消息已删除"
            )


        except Exception:

            pass
